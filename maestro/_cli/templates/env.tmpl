# Create a long-lived access token at <your-hass-url>/profile/security
HOME_ASSISTANT_URL=http://192.168.1.100:8123
HOME_ASSISTANT_TOKEN=your-long-lived-access-token-here

# Hostnames match the docker compose service names
REDIS_HOST=redis
REDIS_PORT=6379

POSTGRES_PASSWORD=maestro
DATABASE_URL=postgresql+psycopg://maestro:maestro@postgres:5432/maestro

TIMEZONE=$timezone
AUTOPOPULATE_REGISTRY=True
DOMAIN_IGNORE_LIST=automation,conversation,remote,stt,tts

# Maps person entity IDs to HA notify actions for push notifications, e.g.
# NOTIFY_ACTION_MAPPINGS=person.john_doe:mobile_app_john_doe_s_iphone,person.jane_doe:mobile_app_jane_doe_s_iphone
NOTIFY_ACTION_MAPPINGS=
